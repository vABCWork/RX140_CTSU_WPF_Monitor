<Window x:Class="CommTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommTest"
        xmlns:wpf="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
         ResizeMode="CanResizeWithGrip" 
        Title="CTSU Monitor" Height="700" Width="950" FontSize="14" FontFamily="MS UI Gothic"  Background="#fcfcfc" Foreground="#333333" >
    <Grid>
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Height" Value="30" />
                <Setter Property="Width" Value="100"/>
                <Setter Property="Margin" Value="10" />
                <Setter Property="BorderBrush" Value="#a6a6a6" />
                <Setter Property="Foreground" Value="#333333" />
                <Setter Property="Background" Value="#fcfcfc"/>
            </Style>
        </Grid.Resources>
        
        <!--　カラム Grid 横方向の大きさ指定。 "AUTO"は、横幅を変更するGridSplitterの部分  -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" MinWidth="100" />
            <ColumnDefinition Width="AUTO"/>
            <ColumnDefinition Width="3*" MinWidth="100" />
        </Grid.ColumnDefinitions>

        <!-- Grid 行方向の大きさ指定 "AUTO"は、高さを変更する GridSplitterの部分-->
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"  MinHeight="100" />
            <RowDefinition Height="AUTO"  />
            <RowDefinition Height="1*" MinHeight="100" />
        </Grid.RowDefinitions>


        <!--横幅を変更する GridSplitter-->
        <GridSplitter Grid.Row="0" Grid.Column="1"   Grid.RowSpan="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Gainsboro"/>

        <!--高さを変更する GridSplitter-->
        <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Gainsboro"/>

        <!-- Scott Plotの配置 -->
        <wpf:WpfPlot Name="wpfPlot_Trend"  Grid.Row="0" Grid.Column="0" Margin="10" />


        <!--　スタックパネル (row=2,col=0)　送信ボタンを配置-->
        <!-- row= 1 には、Gridsplitterが配置されている -->
        <StackPanel Grid.Row="2" Grid.Column="0"  Margin="0">
            <StackPanel Orientation="Horizontal"  Margin="1,10,0,0">
                <Label Content="Monitor:" Margin="0,10,0,10"/>
                <Button Content="Start"   Click="Start_Monitor_Button_Click" />
                <Button Content="Stop"   Click="Stop_Monitor_Button_Click" />
                <Button Content="Test Send"  Click="Test_Send_Button_Click" Margin="40,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"  Margin="1,10,0,0">
                <Label Content="Data   :" Margin="0,10,0,10"/>
                <Button Content="Save"   Click="Save_Button_Click"/>
                <Button Content="Clear"   Click="Clear_Button_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"  Margin="1,10,0,0">
                <Button Content="History"   Margin="60,10,0,10"  Click="History_Button_Click" />
            </StackPanel>

           
            
        </StackPanel>

        <!-- col= 1 には、Gridsplitterが配置されている -->
        <StackPanel Grid.Row="0" Grid.Column="2"  Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="Ch0_CheckBox" Margin="8,4,8,8" IsChecked="True"  Checked="CH_N_Show" Unchecked="CH_N_Hide"/>
                <Label  Content ="TS14:" Margin="0,0,0,0"/>
                <TextBox x:Name="Ch0_TextBox" Text="---"  Margin="0,5,0,0" IsReadOnly="True" BorderThickness="0"/>
                <TextBox x:Name="Ch0_TextBox_Hex" Text="---"  Margin="20,5,0,0" IsReadOnly="True" BorderThickness="0"/>

            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="Ch1_CheckBox" Margin="8,4,8,8" IsChecked="True"  Checked="CH_N_Show" Unchecked="CH_N_Hide"  />
                <Label Content ="TS15:" Margin="0,0,0,0"/>
                <TextBox x:Name="Ch1_TextBox" Text="---"  Margin="0,5,0,0" IsReadOnly="True" BorderThickness="0"/>
                <TextBox x:Name="Ch1_TextBox_Hex" Text="---"  Margin="20,5,0,0" IsReadOnly="True" BorderThickness="0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="Ch2_CheckBox" Margin="8,4,8,8" IsChecked="True"  Checked="CH_N_Show" Unchecked="CH_N_Hide" />
                <Label Content ="Ch2:" Margin="0,0,0,0"/>
                <TextBox x:Name="Ch2_TextBox" Text="---"  Margin="0,5,0,0" IsReadOnly="True" BorderThickness="0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="Ch3_CheckBox"  Margin="8,4,8,8" IsChecked="True"  Checked="CH_N_Show" Unchecked="CH_N_Hide"/>
                <Label Content ="Ch3:" Margin="0,0,0,0"/>
                <TextBox x:Name="Ch3_TextBox" Text="---"  Margin="0,5,0,0" IsReadOnly="True" BorderThickness="0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content ="CTSUSR (TS14):" Margin="0,0,0,0"/>
                <TextBox x:Name="CTSUSR_TS14_TextBox" Text="---"  Margin="0,5,0,0" IsReadOnly="True" BorderThickness="0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content ="CTSUSR (TS15):" Margin="0,0,0,0"/>
                <TextBox x:Name="CTSUSR_TS15_TextBox" Text="---"  Margin="0,5,0,0" IsReadOnly="True" BorderThickness="0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                <Label Content="Memo:" Margin="10,2,0,0" />
                <TextBox x:Name="DataMemoTextBox" Text="xxxxxx      "   IsReadOnly="False" BorderThickness="1" Margin="4,6,0,0"/>
            </StackPanel>

        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="2">
            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                <TextBlock Text="Port:" Margin="0,10,0,0"/>
                <TextBox x:Name="OpenInfoTextBox"   IsReadOnly="True" BorderThickness="0"  Margin ="0,10,0,0" Text ="Open/Close"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <ComboBox  x:Name = "ComPortComboBox"   TextSearch.TextPath="ComPortName" Height="30" Width="100" Margin="10,0,0,0" BorderBrush="#a6a6a6" Foreground="#333333" Background="#fcfcfc">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"  >
                                <!--データバインド-->
                                <TextBlock Text="{Binding ComPortName}"  />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

              <Button x:Name= "ComPortOpenButton" Content="Open" Click="ComPortOpenButton_Click" Margin="30,0,0,0"/>
            </StackPanel>
         
            <StackPanel Orientation="Horizontal" Margin="130,10,0,0" >
                    <Button x:Name= "ComPortSearchButton"  Content="Search" Margin="10,0,0,0" Click="ComPortSearchButton_Click"/>
             </StackPanel>
         
            
            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <TextBlock Text="Baud rate:"/>
                <TextBox x:Name="BaudrateTextBox" IsReadOnly="True" BorderThickness="0"  Margin ="0" Text ="    " />
                <TextBlock Text="[bps]"/>
                <TextBlock Text="  (1-stop, no-parity)"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <TextBlock Text="Send:"/>
                <TextBox x:Name="SendTextBox"   IsReadOnly="True" BorderThickness="1"  Margin ="0,0,2,0" Text =""/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <TextBlock Text="Rcv:"/>
                <TextBox x:Name="RcvTextBox"   IsReadOnly="True" BorderThickness="1"  Margin ="0,0,2,0" Text =""/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                <TextBlock Text="Alarm:"/>
                <TextBox x:Name="AlarmTextBox"   IsReadOnly="True" BorderThickness="1"  Margin ="0,0,2,0" Text =""/>
            </StackPanel>


        </StackPanel>




    </Grid>
</Window>
